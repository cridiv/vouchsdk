# Database connection string (e.g. Postgres) used by Prisma
DATABASE_URL="postgresql://username:password@host:port/database?schema=public"

# Proxycheck API Key (optional/required for fraud check services)
PROXYCHECK_API_KEY=your_proxycheck_api_key

# Port to run the NestJS server on (optional, defaults to 3000)
PORT=3000

# Machine Learning service URL (optional, defaults to https://vouch-2uoc.onrender.com)
ML_SERVICE_URL=https://vouch-2uoc.onrender.com

# Node Environment (optional: development, production, test)
NODE_ENV=development
