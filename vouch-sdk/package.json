{
  "name": "vouch-sdk",
  "version": "1.3.2",
  "description": "TypeScript SDK client library for the Vouch (TrustLayer) platform",
  "keywords": [
    "vouch",
    "trust",
    "nomba",
    "escrow",
    "fraud",
    "identity"
  ],
  "license": "MIT",
  "author": "Vouch Team",
  "type": "module",
