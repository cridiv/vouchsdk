{
    "rewrites": [
        {
            "source": "/_mintlify/:path*",
            "destination": "https://cridiv.mintlify.app/_mintlify/:path*"
        },
        {
            "source": "/api/request",
            "destination": "https://cridiv.mintlify.app/_mintlify/api/request"
        },
        {
            "source": "/mintlify-assets/:path*",
            "destination": "https://cridiv.mintlify.app/mintlify-assets/:path*"
        },
        {
            "source": "/docs",
            "destination": "https://cridiv.mintlify.app/docs"
        },
        {
            "source": "/docs/:path*",
            "destination": "https://cridiv.mintlify.app/docs/:path*"
        }
    ]
}