{
    "rewrites": [
        {
            "source": "/_mintlify/:path*",
            "destination": "https://cridiv.mintlify.site/_mintlify/:path*"
        },
        {
            "source": "/api/request",
            "destination": "https://cridiv.mintlify.site/_mintlify/api/request"
        },
        {
            "source": "/mintlify-assets/:path*",
            "destination": "https://cridiv.mintlify.site/mintlify-assets/:path*"
        },
        {
            "source": "/docs",
            "destination": "https://cridiv.mintlify.site/docs"
        },
        {
            "source": "/docs/:path*",
            "destination": "https://cridiv.mintlify.site/docs/:path*"
        }
    ]
}